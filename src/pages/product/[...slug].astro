---
import ContentPage from '../../layouts/ContentPage.astro';
import { products } from '../../data/kidiko';
import { resolvePath } from '../../utils/navigation';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
---

<ContentPage title={product.name} description={product.description} eyebrow="Paket Kidiko">
  <div class="grid gap-8 lg:grid-cols-[1fr_320px]">
    <article class="rounded-xl border border-slate-200 bg-white p-8 dark:border-slate-800 dark:bg-slate-900">
      <p class="font-semibold text-primary-700 dark:text-primary-300">{product.capacity}</p>
      <h2 class="mt-3 text-3xl font-bold text-slate-950 dark:text-white">{product.name}</h2>
      <p class="mt-5 text-lg leading-8 text-slate-600 dark:text-slate-300">{product.description}</p>
      <h3 class="mt-8 text-xl font-bold text-slate-950 dark:text-white">Fitur utama</h3>
      <ul class="mt-4 grid gap-3 md:grid-cols-2">
        {product.features.map((feature) => (
          <li class="rounded-xl bg-slate-50 p-4 text-slate-700 dark:bg-slate-800 dark:text-slate-200">{feature}</li>
        ))}
      </ul>
    </article>
    <aside class="rounded-xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
      <h3 class="text-xl font-bold text-slate-950 dark:text-white">Cocok untuk</h3>
      <p class="mt-3 text-slate-600 dark:text-slate-300">{product.audience}</p>
      <a href={resolvePath('/kontak/')} class="mt-6 inline-flex w-full justify-center rounded-xl bg-primary-600 px-5 py-3 font-semibold text-white hover:bg-primary-700">Tanya paket ini</a>
    </aside>
  </div>
</ContentPage>
