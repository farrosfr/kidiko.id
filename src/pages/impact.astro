---
import ContentPage from '../layouts/ContentPage.astro';
---

<ContentPage title="Impact" description="Di Kidiko, kami memiliki visi sederhana namun berdampak: membantu akses pendidikan AI yang aman, ringan, dan bisa dipantau oleh pendidik.">
  <div class="grid gap-5 md:grid-cols-3">
    {[
      ['Akses', 'AI dapat dipakai langsung dari WhatsApp tanpa aplikasi tambahan.'],
      ['Keamanan', 'Moderasi menjaga siswa dari prompt berbahaya dan penyalahgunaan.'],
      ['Kendali guru', 'Aktivitas belajar bisa dipantau dan respons penting bisa divalidasi.'],
    ].map(([title, text]) => (
      <article class="rounded-xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
        <h2 class="text-2xl font-bold text-slate-950 dark:text-white">{title}</h2>
        <p class="mt-3 leading-7 text-slate-600 dark:text-slate-300">{text}</p>
      </article>
    ))}
  </div>
</ContentPage>
