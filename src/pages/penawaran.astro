---
import ContentPage from '../layouts/ContentPage.astro';
import { pillars, products } from '../data/kidiko';
import { resolvePath } from '../utils/navigation';
---

<ContentPage title="Penawaran Kidiko" description="Paket AI WhatsApp untuk pembelajaran yang aman, terpantau, dan dapat disesuaikan dengan materi kelas melalui RAG.">
  <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
    <div class="rounded-xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-2xl font-bold text-slate-950 dark:text-white">Yang termasuk</h2>
      <ul class="mt-5 space-y-3 text-slate-700 dark:text-slate-200">
        {pillars.map((item) => <li class="border-l-4 border-primary-500 pl-3">{item.title}: {item.text}</li>)}
      </ul>
    </div>
    <div class="grid gap-4">
      {products.slice(1).map((product) => (
        <a href={resolvePath(`/product/${product.slug}/`)} class="rounded-xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-900">
          <h3 class="font-bold text-slate-950 dark:text-white">{product.name}</h3>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">{product.audience} · {product.capacity}</p>
        </a>
      ))}
    </div>
  </div>
</ContentPage>
