---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { pillars, products } from '../data/kidiko';
import { resolvePath } from '../utils/navigation';
---

<BaseLayout title="Selamat datang di Kidiko" description="Kidiko adalah AI pendamping pendidikan di grup WhatsApp untuk membantu siswa, guru, kelas, keluarga, dan komunitas belajar.">
  <Hero />

  <section id="features" class="bg-slate-50 py-20 dark:bg-slate-950">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase text-primary-700 dark:text-primary-300">Pendamping AI yang inovatif</p>
        <h2 class="mt-3 text-4xl font-heading font-extrabold text-slate-950 dark:text-white">Belajar tetap sosial, guru tetap punya kendali.</h2>
        <p class="mt-5 text-lg leading-8 text-slate-600 dark:text-slate-300">
          Kidiko memakai WhatsApp dan Baileys sebagai kanal yang akrab, ringan, dan fleksibel untuk daerah dengan koneksi internet terbatas.
        </p>
      </div>

      <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {pillars.map((item) => (
          <article class="reveal-on-scroll rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-1 hover:scale-[1.02] hover:shadow-lg dark:border-slate-800 dark:bg-slate-900">
            <h3 class="text-xl font-bold text-slate-950 dark:text-white">{item.title}</h3>
            <p class="mt-3 leading-7 text-slate-600 dark:text-slate-300">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-20 dark:bg-[#09090b]">
    <div class="container mx-auto grid gap-12 px-4 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:px-8">
      <div class="reveal-on-scroll">
        <p class="text-sm font-semibold uppercase text-primary-700 dark:text-primary-300">Alur penggunaan</p>
        <h2 class="mt-3 text-4xl font-heading font-extrabold text-slate-950 dark:text-white">Dari pertanyaan siswa ke validasi guru.</h2>
        <p class="mt-5 text-lg leading-8 text-slate-600 dark:text-slate-300">
          AI menjawab berdasarkan konteks, guru melihat aktivitas, dan kelas tetap bisa berdiskusi tanpa berpindah platform.
        </p>
      </div>
      <div class="grid gap-4">
        {['Siswa bertanya di grup WhatsApp kelas.', 'Kidiko memeriksa keamanan prompt dan mengambil konteks dari materi RAG.', 'AI memberi jawaban yang bisa dibahas lagi bersama teman sekelas.', 'Guru memantau ringkasan aktivitas dan memvalidasi respons penting.'].map((step, index) => (
          <div class="reveal-on-scroll flex gap-4 rounded-xl border border-slate-200 bg-slate-50 p-5 transition-all hover:scale-[1.01] dark:border-slate-800 dark:bg-slate-900" style={`transition-delay: ${index * 100}ms`}>
            <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary-600 font-bold text-white shadow-lg shadow-primary-500/20">{index + 1}</span>
            <p class="self-center text-slate-700 dark:text-slate-200">{step}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-20 dark:bg-slate-950">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col justify-between gap-5 md:flex-row md:items-end">
        <div>
          <p class="text-sm font-semibold uppercase text-primary-700 dark:text-primary-300">Paket Kidiko</p>
          <h2 class="mt-3 text-4xl font-heading font-extrabold text-slate-950 dark:text-white">Pilihan untuk keluarga, kelas, dan komunitas.</h2>
        </div>
        <a href={resolvePath('/toko/')} class="font-semibold text-primary-700 hover:text-primary-800 dark:text-primary-300 transition-colors">Lihat semua paket</a>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {products.slice(0, 6).map((product) => (
          <a href={resolvePath(`/product/${product.slug}/`)} class="reveal-on-scroll rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-1 hover:scale-[1.02] hover:shadow-lg dark:border-slate-800 dark:bg-slate-900">
            <p class="text-sm font-semibold text-accent-700 dark:text-accent-300">{product.capacity}</p>
            <h3 class="mt-2 text-xl font-bold text-slate-950 dark:text-white">{product.name}</h3>
            <p class="mt-3 line-clamp-3 leading-7 text-slate-600 dark:text-slate-300">{product.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-primary-700 py-16 text-white dark:bg-primary-900 overflow-hidden relative">
    <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 w-96 h-96 bg-primary-500 rounded-full blur-3xl opacity-20"></div>
    <div class="container mx-auto flex flex-col justify-between gap-6 px-4 sm:px-6 md:flex-row md:items-center lg:px-8 relative z-10">
      <div class="reveal-on-scroll">
        <h2 class="text-3xl font-heading font-extrabold">Siap menghidupkan grup belajar dengan AI?</h2>
        <p class="mt-3 max-w-2xl text-primary-50">Ceritakan kebutuhan kelas, komunitas, atau keluarga. Kidiko dapat disesuaikan dengan materi dan aturan belajar.</p>
      </div>
      <a href={resolvePath('/kontak/')} class="reveal-on-scroll inline-flex rounded-xl bg-white px-5 py-3 font-semibold text-primary-800 transition-all hover:bg-primary-50 hover:scale-105 active:scale-95 shadow-xl">
        Hubungi Kidiko
      </a>
    </div>
  </section>
</BaseLayout>
