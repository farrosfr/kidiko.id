---
import ContentPage from '../../layouts/ContentPage.astro';
import { products } from '../../data/kidiko';
import { resolvePath } from '../../utils/navigation';
---

<ContentPage title="Paket AI" description="Kategori paket AI Kidiko untuk grup WhatsApp keluarga, kelas, komunitas, dan latihan terarah.">
  <div class="grid gap-5 md:grid-cols-2">
    {products.map((product) => (
      <a href={resolvePath(`/product/${product.slug}/`)} class="rounded-xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
        <p class="text-sm font-semibold text-accent-700 dark:text-accent-300">{product.capacity}</p>
        <h2 class="mt-2 text-xl font-bold text-slate-950 dark:text-white">{product.name}</h2>
        <p class="mt-3 leading-7 text-slate-600 dark:text-slate-300">{product.description}</p>
      </a>
    ))}
  </div>
</ContentPage>
