---
import ContentPage from '../layouts/ContentPage.astro';
import { products } from '../data/kidiko';
import { resolvePath } from '../utils/navigation';

const product = products.find((item) => item.slug === 'toefl-itp-kidiko');
---

<ContentPage title="TOEFL ITP Kidiko" description="Latihan TOEFL ITP dengan pendamping AI di WhatsApp untuk drilling, pembahasan, dan progres belajar yang lebih mudah dipantau.">
  <div class="rounded-xl border border-slate-200 bg-white p-8 dark:border-slate-800 dark:bg-slate-900">
    <h2 class="text-2xl font-bold text-slate-950 dark:text-white">{product?.name}</h2>
    <p class="mt-4 leading-8 text-slate-600 dark:text-slate-300">{product?.description}</p>
    <ul class="mt-6 grid gap-3 md:grid-cols-2">
      {product?.features.map((feature) => <li class="rounded-xl bg-slate-50 p-4 text-slate-700 dark:bg-slate-800 dark:text-slate-200">{feature}</li>)}
    </ul>
    <a href={resolvePath('/product/toefl-itp-kidiko/')} class="mt-8 inline-flex rounded-xl bg-primary-600 px-5 py-3 font-semibold text-white hover:bg-primary-700">Lihat detail program</a>
  </div>
</ContentPage>
