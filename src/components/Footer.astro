---
import { FOOTER_LINKS, BRAND_NAME, BRAND_LOGO_TEXT, SITE_DESCRIPTION, SOCIAL_LINKS } from '../config';
import { resolvePath } from '../utils/navigation';
---

<footer class="bg-white dark:bg-[#09090b] border-t border-slate-200 dark:border-slate-800 pt-16 pb-8 transition-colors">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-[minmax(280px,1.35fr)_repeat(3,minmax(140px,1fr))] lg:gap-10 mb-12">
      <div>
        <a href={resolvePath('/')} class="flex items-center mb-4 group transition-transform active:scale-95">
          <img src={resolvePath('/logo.png')} alt={BRAND_NAME} class="h-8 w-auto rounded-xl shadow-lg shadow-primary-500/20" />
        </a>
        <p class="text-slate-600 dark:text-slate-400 text-sm mb-6 leading-relaxed">
          {SITE_DESCRIPTION}
        </p>
        <a href={resolvePath('/kontak/')} class="inline-flex rounded-xl bg-primary-600 px-4 py-2.5 text-sm font-semibold text-white transition-all hover:bg-primary-700 hover:shadow-lg hover:shadow-primary-500/20 active:scale-[0.98]">
          Diskusi kebutuhan kelas
        </a>
      </div>

      <!-- Links -->
      {FOOTER_LINKS.map(group => (
        <div>
          <h3 class="font-semibold text-slate-900 dark:text-white mb-4">{group.title}</h3>
          <ul class="space-y-3">
            {group.links.map(link => (
              <li>
                <a href={resolvePath(link.href)} class="text-sm text-slate-600 dark:text-slate-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="border-t border-slate-200 dark:border-slate-800 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-slate-500 dark:text-slate-400">
        &copy; {new Date().getFullYear()} {BRAND_NAME}. All rights reserved.
      </p>
      
      <p class="text-sm text-slate-500 dark:text-slate-400">
        Made by <a href="https://farrosfr.com" class="font-semibold text-primary-600 dark:text-primary-400 hover:underline" rel="dofollow">Farros FR</a>
      </p>
    </div>
  </div>
</footer>

