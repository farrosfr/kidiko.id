---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
}

const { title, description, eyebrow = 'Kidiko.id' } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <section class="border-b border-slate-200 bg-white py-16 dark:border-slate-800 dark:bg-[#09090b] sm:py-20">
    <div class="container mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <p class="mb-4 text-sm font-semibold uppercase text-primary-700 dark:text-primary-300">{eyebrow}</p>
      <h1 class="max-w-3xl text-4xl font-heading font-extrabold leading-tight text-slate-950 dark:text-white sm:text-5xl">
        {title}
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600 dark:text-slate-300">{description}</p>
    </div>
  </section>
  <section class="bg-slate-50 py-14 dark:bg-slate-950">
    <div class="container mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <slot />
    </div>
  </section>
</BaseLayout>
